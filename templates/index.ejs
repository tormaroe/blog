<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="google-site-verification" content="_aW0kkWIpvOEZE9h9EGvvwWWlm5MbCSDWC1ZJBrLuqk" />
    <meta name="description" content="Variert blogg for programmerere">
    <meta name="keywords" content="programmering">
    <meta name="author" content="Torbjørn Marø">

    <title>Programmeringsbloggen</title>

    <!-- Bootstrap core CSS -->
    <link href="/assets/css/bootstrap.css" rel="stylesheet">

    <!-- Custom styles for this template -->
    <link href="/assets/css/kjempekjekt.css" rel="stylesheet">
    <link href="/assets/js/jquery.counter-analog.css" media="screen" rel="stylesheet" type="text/css" />
    <link href="/assets/js/jquery.counter-analog2.css" media="screen" rel="stylesheet" type="text/css" />

    <!-- HTML5 shim and Respond.js IE8 support of HTML5 elements and media queries -->
    <!--[if lt IE 9]>
      <script src="https://oss.maxcdn.com/libs/html5shiv/3.7.0/html5shiv.js"></script>
      <script src="https://oss.maxcdn.com/libs/respond.js/1.3.0/respond.min.js"></script>
    <![endif]-->
  </head>

  <body>
    <% include navbar %>

    <!-- Main jumbotron for a primary marketing message or call to action -->
      <div class="container" style="padding-top:10px;padding-bottom:10px;">
        <p><%= data.postCount %> bloggposter fra 2006 til <%= new Date().getFullYear() %> om objektorientert og funksjonell programmering, smidige teknikker, metaprogrammering og DSL'er,
        språk som C#, F#, Ruby, JavaScript, Erlang og Clojure, generelle meningsytringer og mye mer..</p>
      </div>

    <div class="container">
      <!-- Example row of columns -->
      <div class="row">
        <div class="col-md-9">
          <% data.posts.forEach(function(post) { %>
            <h2><a href="<%- post.data.link %>"><%= post.data.title %></a></h2>
            <p><small><%= post.data.date %></small></p>
            <p><%= post.content %> [...]</p>
            <p><a href="<%- post.data.link %>">Les mer &raquo;</a></p>
          <% }); %>
        </div>
        <div class="col-md-3">
          <div class="thumbnail">
            <img src="assets/images/bb/<%= data.featured.image %>">
            <div class="caption">
              <h4><%= data.featured.heading %></h4>
              <p><%= data.featured.text %></p>
              <p class="text-center"><a href="<%- data.featured.link %>" class="btn btn-primary" role="button">Les hele artikkelen &raquo;</a></p>
            </div>
          </div>
          <div class="thumbnail">
            <img src="assets/images/bb/<%= data.featuredTag.image %>">
            <div class="caption">
              <h4><%= data.featuredTag.name %></h4>
              <p><%= data.featuredTag.text %></p>
              <p class="text-center"><a href="http://blog.kjempekjekt.com/tags/<%- data.featuredTag.slug %>" class="btn btn-primary" role="button">Alle relaterte artikler &raquo;</a></p>
            </div>
          </div>
          <div class="thumbnail">
            <img src="assets/images/bb/<%= data.featuredTag2.image %>">
            <div class="caption">
              <h4><%= data.featuredTag2.name %></h4>
              <p><%= data.featuredTag2.text %></p>
              <p class="text-center"><a href="http://blog.kjempekjekt.com/tags/<%- data.featuredTag2.slug %>" class="btn btn-primary" role="button">Alle relaterte artikler &raquo;</a></p>
            </div>
          </div>
        </div>
      </div>

      <div class="row" style="margin-top:40px;">
        <div class="col-sm-12">
          <p class="text-center">
            <b>Noen utvalgte tags:</b><br>
            <a class="btn btn-success tagbtn" href="/tags/books"><b>Bøker</b></a>
            <a class="btn btn-success tagbtn" href="/tags/csharp"><b>C#</b></a>
            <a class="btn btn-success tagbtn" href="/tags/clojure"><b>Clojure</b></a>
            <a class="btn btn-success tagbtn" href="/tags/erlang"><b>Erlang</b></a>
            <a class="btn btn-success tagbtn" href="/tags/julekalender"><b>Julekalender</b></a>
            <a class="btn btn-success tagbtn" href="/tags/ledelse"><b>Ledelse</b></a>
            <a class="btn btn-success tagbtn" href="/tags/meninger"><b>Meninger</b></a>
            <a class="btn btn-success tagbtn" href="/tags/oo-patterns"><b>OO Patterns</b></a>
            <br>
            <a href="/tags/"><i>Liste over alle tags &raquo;</i></a>
          </p>
        </div>
      </div>
      
      <% include footer %>
    </div> <!-- /container -->


    <script src="https://code.jquery.com/jquery-1.10.2.min.js"></script>
    <script src="/assets/js/bootstrap.min.js"></script>
    <script src="/assets/js/jquery.counter.js"></script>
    <script src="/assets/js/kjempekjekt.js"></script>
    <script type="text/javascript">
      $(function () {
        $("#postCountTicker").addClass('counter counter-analog2').counter({
          initial: "0",
          direction: 'up',
          format: "999",
          interval: 10,
          stop: "<%= data.postCount %>"
        });
      });
    </script>
  </body>
</html>

